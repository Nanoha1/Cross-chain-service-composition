# p2p network config

# Module is the name of p2p module plugin.(p2pv1 | p2pv2)
module: p2pv2
# Port the p2p network listened
port: 47123
# Address multiaddr string
address: /ip4/0.0.0.0/tcp/47123
# IsTls config the node use tls secure transparent
isTls: false
# KeyPath is the netdisk private key path
keyPath: netkeys
# BootNodes config the bootNodes the node to connect
bootNodes:
  - "/ip4/172.18.0.4/tcp/47103/p2p/Qmf2HeHe4sspGkfRCTq6257Vm3UHzvh2TeQJHHvHzzuFw6"
  - "/ip4/172.18.0.8/tcp/47113/p2p/QmQKp8pLWSgV4JiGjuULKV1JsdpxUtnDEUMP8sGaaUbwVL"

serviceName: localhost

